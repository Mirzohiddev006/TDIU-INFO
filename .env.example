# TDIU Info Bot — muhit o'zgaruvchilari
# Ushbu faylni nusxalab .env deb nomlang va qiymatlarni to'ldiring.

# @BotFather dan olingan bot tokeni
BOT_TOKEN=
# Operatorlar / adminlar Telegram ID'lari (vergul bilan ajratiladi).
# Operatorga yo'naltirilgan so'rovlar shu ID'larga yuboriladi.
# O'z ID'ingizni @userinfobot dan olishingiz mumkin.
ADMIN_IDS=

# Qabul komissiyasi Telegram username (masalan: tdiu_qabul) — operator yo'q paytda ko'rsatiladi
SUPPORT_USERNAME=

# Ma'lumotlar bazasi (backend bilan BIR XIL bo'lishi shart)
# SQLite (standart): sqlite+aiosqlite:///./tdiu.db
# PostgreSQL: postgresql+asyncpg://tdiu:parol@localhost:5432/tdiu
DATABASE_URL=sqlite+aiosqlite:///./tdiu.db
ADMISSION_YEAR=2025/2026

# Keep-alive (Render.com uchun) — har necha daqiqada self-ping
KEEPALIVE_MINUTES=14
# Render avtomatik RENDER_EXTERNAL_URL beradi. Lokalda sinash uchun:
# KEEPALIVE_URL=https://tdiu-info-bot.onrender.com
