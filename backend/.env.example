# Ma'lumotlar bazasi (bot bilan BIR XIL bo'lishi shart!)
# DIQQAT: bu NAMUNA fayl — bu yerga HAQIQIY parol/connection string YOZMANG!
# Haqiqiy DATABASE_URL'ni faqat .env (git'ga tushmaydigan) yoki Render env'ga qo'ying.
#
# SQLite (standart, o'rnatishsiz):
# DATABASE_URL=sqlite+aiosqlite:///./tdiu.db
# Neon/PostgreSQL (production) — namuna ko'rinishi:
# DATABASE_URL=postgresql://FOYDALANUVCHI:PAROL@HOST.neon.tech/DBNOMI?sslmode=require

ADMISSION_YEAR=2025/2026

# JWT — production da albatta o'zgartiring
JWT_SECRET=CHANGE-ME-please
JWT_EXPIRE_MINUTES=720

# Birinchi super-admin (seed paytida yaratiladi)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
